# vCISO Platform — Environment Variables
# Copy to .env.local and fill in values. NEVER commit .env.local.

# Claude API key (server-side only — NEVER prefix with NEXT_PUBLIC_)
ANTHROPIC_API_KEY=sk-ant-...

# Gamma.app API key for PowerPoint export (Epic 5 — not required until Story 5.2)
# GAMMA_API_KEY=

# Optional: canonical URL for OG tags
# NEXT_PUBLIC_APP_URL=https://vciso-platform.vercel.app
