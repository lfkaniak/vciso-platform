{
  "functions": {
    "app/api/vciso/route.ts": { "maxDuration": 60 },
    "app/api/artifacts/[type]/route.ts": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    }
  ]
}
